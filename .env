# Firebase Configuration
# ⚠️ IMPORTANTE: REEMPLAZA ESTOS VALORES CON TUS CREDENCIALES REALES
# Obtener valores de: https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# App Configuration
VITE_APP_ENV=development
VITE_APP_NAME=Plataforma Escolar

# Rate Limiting (en segundos)
VITE_SECURITY_ROUTE_RATE_LIMIT=300
VITE_SECURITY_ROUTE_MAX_ATTEMPTS=3

# MediaMTX Configuration (para streaming de cámaras)
# ⚠️ Asegúrate de que MediaMTX esté corriendo en estos puertos
VITE_MEDIAMTX_HLS_BASE=http://localhost:8888
VITE_MEDIAMTX_WEBRTC_BASE=http://localhost:8889

# Opcional: Servicios de monitoreo
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
